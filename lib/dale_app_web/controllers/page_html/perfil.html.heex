      </div>

      <div style="flex:1; display:flex; flex-direction:column; gap:11px; align-self:center; background:#fff; border:3px solid #186904; border-radius:22px; padding:16px;">
        <div class="dp-nivel" onclick="dpToggleNivel(4)" style="border:2px solid #e8e8e8; border-radius:16px; padding:14px 16px; cursor:pointer; background:#fff;">
