          </div>
        </div>
        <div class="dp-nivel" onclick="dpToggleNivel(2)" style="border:2px solid #e8e8e8; border-radius:16px; padding:14px 16px; cursor:pointer; background:#fff;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:15px; font-weight:700; color:#000; font-family:Poppins,sans-serif;">Nivel 2 · 2000</span>
            <span id="dp-flecha-2" style="font-size:11px; color:#999; transition:transform 0.2s;">&#9660;</span>
