    <div style="display:flex; gap:8px; justify-content:center; margin-top:20px; flex-wrap:wrap;">
      <button onclick="dpAdd()" style="padding:8px 12px; border:2px solid #ddd; background:#fafafa; color:#888; border-radius:10px; font-family:Poppins,sans-serif; font-size:11px; cursor:pointer;">+ líquido</button>
      <button onclick="dpSub()" style="padding:8px 12px; border:2px solid #ddd; background:#fafafa; color:#888; border-radius:10px; font-family:Poppins,sans-serif; font-size:11px; cursor:pointer;">− líquido</button>
      <button onclick="dpCupon()" style="padding:8px 12px; border:2px solid #ddd; background:#fafafa; color:#888; border-radius:10px; font-family:Poppins,sans-serif; font-size:11px; cursor:pointer;">🎟️ cupón</button>
    </div>
    <p style="font-size:9px; color:#bbb; text-align:center; font-family:Poppins,sans-serif; margin:6px 0 0;">Botones de prueba (provisorios)</p>
  </div>

  <script>
    (function() {
      var slider = document.getElementById('perfil-slider');
      var dots = [document.getElementById('pdot-0'), document.getElementById('pdot-1'), document.getElementById('pdot-2')];
      function irAlCentro() { slider.scrollLeft = slider.clientWidth; }
      irAlCentro();
      window.addEventListener('load', irAlCentro);
      var raf;
      slider.addEventListener('scroll', function() {
        if (raf) return;
        raf = requestAnimationFrame(function() {
          var idx = Math.round(slider.scrollLeft / slider.clientWidth);
          dots.forEach(function(d, i) { if (d) d.classList.toggle('activo', i === idx); });
          raf = null;
        });
      });
    })();
  </script>
</div>

<script>
  const csrfTokenPerfil = document.querySelector("meta[name='csrf-token']")?.getAttribute("content");

  function abrirEditorUsername() {
    const editor = document.getElementById('editor-username');
    editor.style.display = editor.style.display === 'none' ? 'block' : 'none';
  }

  async function guardarUsername() {
    const username = document.getElementById('nuevo-username').value.trim();
    const errorEl = document.getElementById('username-error');
    const res = await fetch('/perfil/username', {
      method: 'POST',
      headers: { 'x-csrf-token': csrfTokenPerfil, 'content-type': 'application/json' },
      body: JSON.stringify({ username: username })
    });
    const data = await res.json();
    if (data.ok) {
      document.getElementById('username-display').textContent = data.username;
      document.getElementById('editor-username').style.display = 'none';
      document.getElementById('nuevo-username').value = '';
      errorEl.style.display = 'none';
    } else {
      errorEl.textContent = data.error;
      errorEl.style.display = 'block';
    }
  }

  async function subirFotoPerfil(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      const preview = document.getElementById('foto-preview');
      if (preview.tagName === 'IMG') preview.src = e.target.result;
    };
    reader.readAsDataURL(file);
    const formData = new FormData();
    formData.append('_csrf_token', csrfTokenPerfil);
    formData.append('foto', file);
    const res = await fetch('/perfil/foto', { method: 'POST', body: formData });
    const data = await res.json();
    if (!data.ok) alert('Error al subir la foto');
  }
</script>

<!-- CROPPER JS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

<!-- MODAL CROPPER -->
<!-- MODAL CROPPER VITRINA -->
<div id="vitrina-cropper-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.92); z-index:100001; flex-direction:column;">
  <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 16px;">
    <button onclick="cerrarCropperVitrina()" style="background:none; border:none; color:white; font-size:22px; cursor:pointer;">&#x2715;</button>
    <p style="color:white; font-size:15px; font-weight:700; margin:0; font-family:Poppins,sans-serif;">Ajustá la imagen</p>
    <button onclick="confirmarCropVitrina()" style="background:none; border:none; color:#44BB64; font-size:15px; font-weight:700; cursor:pointer; font-family:Poppins,sans-serif;">Listo ✓</button>
  </div>
  <div style="flex:1; display:flex; align-items:center; justify-content:center; overflow:hidden; padding:0 16px;">
    <img id="vitrina-cropper-img" style="max-width:100%; max-height:100%;"/>
  </div>
  <input type="file" id="vitrina-input" accept="image/*" style="display:none;" onchange="elegirFotoVitrina(this)"/>
</div>

<script>
  let vitrinaCropperInstance = null;
  function abrirCropperVitrina() {
    document.getElementById('vitrina-input').click();
  }
  function elegirFotoVitrina(input) {
    const file = input.files[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    const imgEl = document.getElementById('vitrina-cropper-img');
    imgEl.src = url;
    document.getElementById('vitrina-cropper-modal').style.display = 'flex';
    document.getElementById('navbar').style.display = 'none';
    setTimeout(() => {
      if (vitrinaCropperInstance) { vitrinaCropperInstance.destroy(); vitrinaCropperInstance = null; }
      vitrinaCropperInstance = new Cropper(imgEl, {
        aspectRatio: 3 / 1,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        guides: false,
        center: false,
        highlight: false,
        cropBoxMovable: false,
        cropBoxResizable: false,
        toggleDragModeOnDblclick: false,
      });
    }, 200);
  }
  function cerrarCropperVitrina() {
    if (vitrinaCropperInstance) { vitrinaCropperInstance.destroy(); vitrinaCropperInstance = null; }
    document.getElementById('vitrina-cropper-modal').style.display = 'none';
    document.getElementById('vitrina-input').value = '';
    document.getElementById('navbar').style.display = '';
  }
  function confirmarCropVitrina() {
    if (!vitrinaCropperInstance) return;
    const canvas = vitrinaCropperInstance.getCroppedCanvas({ width: 1200, height: 400 });
    canvas.toBlob(blob => {
      const formData = new FormData();
      formData.append('_csrf_token', csrfTokenPerfil);
      formData.append('foto', blob, 'vitrina.jpg');
      fetch('/perfil/vitrina', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
          if (data.ok) {
            const cont = document.querySelector('[onclick="abrirCropperVitrina()"]');
            cont.innerHTML = '<img id="vitrina-img" src="' + data.url + '" style="width:100%; height:100%; object-fit:cover; display:block;"/>';
            cerrarCropperVitrina();
            window.mostrarAviso && window.mostrarAviso('Imagen guardada!');
          } else {
            window.mostrarAviso && window.mostrarAviso('Error al subir');
          }
        });
    }, 'image/jpeg', 0.9);
  }
</script>

<div id="pub-cropper-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.92); z-index:100000; flex-direction:column;">
  <div style="display:flex; align-items:center; justify-content:space-between; padding:14px 16px;">
    <button onclick="cerrarCropperPub()" style="background:none; border:none; color:white; font-size:22px; cursor:pointer;">&#x2715;</button>
    <p style="color:white; font-size:15px; font-weight:700; margin:0; font-family:'Noto Sans',sans-serif;">Ajustá la foto</p>
    <button onclick="confirmarCropPub()" style="background:none; border:none; color:#44BB64; font-size:15px; font-weight:700; cursor:pointer; font-family:'Noto Sans',sans-serif;">Listo ✓</button>
  </div>
  <div style="flex:1; display:flex; align-items:center; justify-content:center; overflow:hidden; padding:0 16px;">
    <img id="pub-cropper-img" style="max-width:100%; max-height:100%;"/>
  </div>
  <p style="color:#aaa; text-align:center; font-size:12px; padding:12px; font-family:'Noto Sans',sans-serif;">Pellizca para hacer zoom · Arrastrá para encuadrar</p>
</div>

<!-- MODAL NUEVA PUBLICACION -->
<div id="foto-selector-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:white; z-index:99999; flex-direction:column;">

  <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 16px; border-bottom:1px solid #eee;">
    <button onclick="cerrarSelectorFotos()" style="background:none; border:none; color:#186904; font-size:22px; font-weight:700; cursor:pointer; line-height:1;">&#x2715;</button>
    <p style="font-size:15px; font-weight:600; color:#111; margin:0; font-family:'Noto Sans',sans-serif; position:absolute; left:50%; transform:translateX(-50%);">Nueva publicacion</p>
    <button id="btn-siguiente-pub" onclick="irAPaso2()" style="background:none; border:none; color:#186904; font-size:14px; font-weight:700; cursor:pointer; font-family:'Noto Sans',sans-serif;">Siguiente →</button>
  </div>

  <div style="flex:1; overflow-y:auto; padding:48px 32px 16px;">
    <div style="position:relative; width:100%; max-width:400px; min-height:calc(min(100vw - 64px, 400px) * 5 / 3); overflow:visible; background:white; margin-top:20px; margin-bottom:20px;">
      <div id="foto-placeholder" style="width:100%; height:100%; display:flex; flex-direction:column; overflow:visible; position:relative;">
        <div style="background:white; border:1px solid #186904; position:relative; height:90px; display:flex; align-items:center; padding:0 12px 0 80px; overflow:visible;">
          <div style="position:absolute; left:20px; top:5px; width:75px; height:75px; border-radius:50%; overflow:hidden; z-index:10; box-shadow:0 2px 8px rgba(0,0,0,0.3); border:2px solid #186904;">
            <%= if @current_user && @current_user.avatar do %>
              <img src={@current_user.avatar} style="width:100%; height:100%; object-fit:cover; display:block;"/>
            <% end %>
          </div>
          <div style="position:relative; left:25px; top:0px; display:flex; flex-direction:column; gap:6px;">
            <span style="color:#111; font-size:18px; font-weight:200; font-family:'Noto Sans',sans-serif;">@<%= if @current_user, do: @current_user.username, else: "" %></span>
            <button style="background:#186904; color:white; border:none; border-radius:6px; padding:5px 18px; font-size:13px; font-weight:600; font-family:'Noto Sans',sans-serif; cursor:pointer; width:fit-content;">Seguir</button>
          </div>
        </div>
        <div style="height:3px;"></div>
        <div style="background:white; border:1px solid #186904;">
        <div id="pub-placeholder-zona" style="display:flex; align-items:center; justify-content:center; flex-direction:column; gap:8px;" onclick="document.getElementById('input-fotos').click()">
          <div style="width:320px; height:360px; background:white; border-radius:4px; margin-left:auto; margin-right:auto; align-self:center; margin-top:35px; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:8px;">
            <span style="font-size:36px; color:#ddd;">📷</span>
            <p style="font-size:12px; color:#bbb; margin:0; font-family:'Noto Sans',sans-serif;">Tocá para agregar foto</p>
          </div>
        </div>
        <div id="pub-preview-zona" ontouchstart="carouselTouchStart(event)" ontouchend="carouselTouchEnd(event)" style="display:none; width:320px; height:360px; overflow:hidden; cursor:pointer; margin:35px auto 0;" onclick="document.getElementById('input-fotos').click()">
          <img id="pub-preview-img" style="width:100%; height:100%; object-fit:cover; display:block;"/>
        </div>
        <div style="position:relative; margin:0 auto; width:320px; display:flex; align-items:center; justify-content:space-between; padding:10px 0;">
          <div style="display:flex; gap:16px; align-items:center;">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </div>
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div style="position:relative; margin:0 auto; width:320px;">
          <p style="font-size:15px; font-weight:700; color:#111; margin:0 0 4px; font-family:'Noto Sans',sans-serif;">@<%= if @current_user, do: @current_user.username, else: "" %></p>
          <textarea id="pub-descripcion-input" maxlength="1000" placeholder="Escribí algo..." oninput="autoResizeDesc(this)" style="width:100%; border:none; outline:none; resize:none; font-size:13px; font-family:'Noto Sans',sans-serif; color:#444; background:transparent; min-height:20px; height:20px; box-sizing:border-box; overflow:hidden;"></textarea>
        </div>
        </div>
      </div>
    </div>
  </div>

    <input type="file" id="input-fotos" accept="image/*" style="display:none;" onchange="elegirFotoPub(this)"/>
</div>

<script>
  let pubCropperInstance = null;
  let pubImagenesBlobs = [];
  let pubCarouselIndex = 0;

  function irAPaso2() {
    document.getElementById("foto-selector-modal").style.display = "none";
    document.getElementById("pub-paso2-modal").style.display = "flex";
  }

  function abrirSelectorFotos() {
    document.getElementById('foto-selector-modal').style.display = 'flex';
    document.getElementById('navbar').style.display = 'none';
    document.getElementById('input-fotos').click();
  }

  function cerrarSelectorFotos() {
    document.getElementById('foto-selector-modal').style.display = 'none';
    document.getElementById('pub-placeholder-zona').style.display = 'flex';
    document.getElementById('pub-placeholder-zona').querySelector('div').style.display = 'flex';
    document.getElementById('pub-preview-zona').style.display = 'none';
    document.getElementById('pub-descripcion-input').value = '';
    document.getElementById('pub-descripcion-input').style.height = '20px';
    pubImagenesBlobs = [];
    pubCarouselIndex = 0;
    document.getElementById('input-fotos').value = '';
    document.getElementById('navbar').style.display = '';
  }

  function autoResizeDesc(el) {
    el.style.height = 'auto';
    el.style.height = el.scrollHeight + 'px';
  }

  function elegirFotoPub(input) {
    const file = input.files[0];
    if (!file) return;
    document.getElementById('foto-selector-modal').style.display = 'flex';
    document.getElementById('navbar').style.display = 'none';
    const url = URL.createObjectURL(file);
    const imgEl = document.getElementById('pub-cropper-img');
    imgEl.src = url;
    document.getElementById('pub-cropper-modal').style.display = 'flex';
    setTimeout(() => {
      if (pubCropperInstance) { pubCropperInstance.destroy(); pubCropperInstance = null; }
      pubCropperInstance = new Cropper(imgEl, {
        aspectRatio: 4 / 5,
        viewMode: 1,
        dragMode: 'move',
        autoCropArea: 1,
        restore: false,
        guides: false,
        center: false,
        highlight: false,
        cropBoxMovable: false,
        cropBoxResizable: false,
        toggleDragModeOnDblclick: false,
      });
    }, 200);
  }

  function cerrarCropperPub() {
    if (pubCropperInstance) { pubCropperInstance.destroy(); pubCropperInstance = null; }
    document.getElementById('pub-cropper-modal').style.display = 'none';
    document.getElementById('input-fotos').value = '';
    document.getElementById('navbar').style.display = '';
  }

  function confirmarCropPub() {
    if (!pubCropperInstance) return;
    if (pubImagenesBlobs.length >= 4) {
      window.mostrarAviso && window.mostrarAviso("Máximo 4 fotos");
      return;
    }
    const canvas = pubCropperInstance.getCroppedCanvas({ width: 1200, height: 1500 });
    canvas.toBlob(blob => {
      pubImagenesBlobs.push(blob);
      pubCropperInstance.destroy();
      pubCropperInstance = null;
      document.getElementById('pub-cropper-modal').style.display = 'none';
      document.getElementById('pub-placeholder-zona').querySelector('div').style.display = 'none';
      document.getElementById('pub-preview-zona').style.display = 'block';
      renderCarousel();
    }, 'image/jpeg', 0.9);
  }

  function renderCarousel() {
    const zona = document.getElementById('pub-preview-zona');
    zona.ontouchstart = (e) => { touchStartX = e.touches[0].clientX; };
    zona.ontouchend = (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) { if (diff > 0) carouselNext(); else carouselPrev(); }
    };
    const n = pubImagenesBlobs.length;
    zona.innerHTML = `
      <div style="position:relative; width:100%; height:100%; overflow:hidden;">
        <div id="carousel-track" style="display:flex; height:100%; transition:transform 0.3s ease; transform:translateX(-${pubCarouselIndex * 100}%);" ontouchstart="carouselTouchStart(event)" ontouchend="carouselTouchEnd(event)">
          ${pubImagenesBlobs.map((blob, i) => `
            <div style="min-width:100%; height:100%; overflow:hidden; flex-shrink:0;">
              <img src="${URL.createObjectURL(blob)}" style="width:100%; height:100%; object-fit:cover; display:block;"/>
            </div>
          `).join('')}
        </div>
        ${n > 1 ? `
        <button onclick="carouselPrev()" style="position:absolute; left:4px; top:50%; transform:translateY(-50%); background:rgba(0,0,0,0.4); border:none; color:white; border-radius:50%; width:28px; height:28px; cursor:pointer; font-size:14px;">‹</button>
        <button onclick="carouselNext()" style="position:absolute; right:4px; top:50%; transform:translateY(-50%); background:rgba(0,0,0,0.4); border:none; color:white; border-radius:50%; width:28px; height:28px; cursor:pointer; font-size:14px;">›</button>
        ` : ''}
        <div style="position:absolute; bottom:8px; left:50%; transform:translateX(-50%); display:flex; gap:5px; align-items:center; background:rgba(0,0,0,0.3); border-radius:10px; padding:3px 8px;">
          ${pubImagenesBlobs.map((_, i) => `<div style="width:${i===pubCarouselIndex?'18px':'7px'}; height:7px; border-radius:4px; background:${i===pubCarouselIndex?'#186904':'white'}; transition:all 0.3s;"></div>`).join('')}
        </div>
      </div>
      ${n < 4 ? `<button onclick="document.getElementById('input-fotos').click()" style="position:absolute; bottom:-44px; left:50%; transform:translateX(-50%); background:#186904; color:white; border:none; border-radius:20px; padding:8px 20px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Noto Sans',sans-serif; white-space:nowrap;">+ Agregar otra foto</button>` : ''}
    `;
  }

  let touchStartX = 0;
  function carouselTouchStart(e) { touchStartX = e.touches[0].clientX; }
  function carouselTouchEnd(e) {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) {
      if (diff > 0) carouselNext();
      else carouselPrev();
    }
  }

  function carouselPrev() {
    if (pubCarouselIndex > 0) {
      pubCarouselIndex--;
      renderCarousel();
    }
  }

  function carouselNext() {
    if (pubCarouselIndex < pubImagenesBlobs.length - 1) {
      pubCarouselIndex++;
      renderCarousel();
    }
  }
</script>

<!-- MODAL PASO 2 -->
<div id="pub-paso2-modal" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:white; z-index:99999; flex-direction:column;">
  <div style="display:flex; align-items:center; justify-content:space-between; padding:16px 16px; border-bottom:1px solid #eee;">
    <button onclick="volverAPaso1()" style="background:none; border:none; color:#186904; font-size:22px; font-weight:700; cursor:pointer; line-height:1;">←</button>
    <p style="font-size:15px; font-weight:600; color:#111; margin:0; font-family:'Noto Sans',sans-serif; position:absolute; left:50%; transform:translateX(-50%);">Nueva publicacion</p>
    <button onclick="subirPublicacion()" style="background:none; border:none; color:#186904; font-size:14px; font-weight:700; cursor:pointer; font-family:'Noto Sans',sans-serif;">Subir</button>
  </div>
  <div style="flex:1; overflow-y:auto; padding:48px 32px 100px; background:white;">
  </div>
</div>

<script>
  function volverAPaso1() {
    document.getElementById('pub-paso2-modal').style.display = 'none';
    document.getElementById('foto-selector-modal').style.display = 'flex';
  }

  function subirPublicacion() {
    if (pubImagenesBlobs.length === 0) { window.mostrarAviso && window.mostrarAviso("Primero agregá una foto"); return; }
    const descripcion = document.getElementById("pub-descripcion-input").value;
    const formData = new FormData();
    formData.append("_csrf_token", csrfTokenPerfil);
    pubImagenesBlobs.forEach((blob, i) => {
      formData.append("imagenes[]", blob, "publicacion_" + i + ".jpg");
    });
    formData.append("descripcion", descripcion);
    fetch("/publicaciones/crear", { method: "POST", body: formData })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          document.getElementById("pub-paso2-modal").style.display = "none";
          document.getElementById("foto-selector-modal").style.display = "none";
          document.getElementById("navbar").style.display = "";
          pubImagenesBlobs = [];
          pubCarouselIndex = 0;
          window.mostrarAviso && window.mostrarAviso("Publicacion subida!");
        } else {
          window.mostrarAviso && window.mostrarAviso("Error: " + data.error);
        }
      });
  }
</script>

<!-- OVERLAY EDITOR DE PERFIL -->
<div id="editor-overlay" style="position:fixed; top:60px; left:0; right:0; bottom:11vh; background:#fff; z-index:4000; transform:translateY(100%); transition:transform 0.35s cubic-bezier(0.34,1.2,0.5,1); overflow-y:auto; max-width:480px; margin:0 auto;">
  <div style="display:flex; align-items:center; justify-content:space-between; padding:16px; border-bottom:1px solid #eee;">
    <button onclick="intentarCerrarEditor()" style="background:none; border:none; color:#186904; font-size:22px; font-weight:700; cursor:pointer; line-height:1;">&#x2715;</button>
    <p style="font-size:16px; font-weight:700; color:#111; margin:0; font-family:Poppins,sans-serif;">Editar perfil</p>
    <span style="width:22px;"></span>
  </div>
  <div style="padding:20px 18px 40px;">

    <p style="font-size:13px; font-weight:600; color:#186904; margin:0 0 8px; font-family:Poppins,sans-serif;">Nombre de usuario</p>
    <div style="display:flex; gap:8px; margin-bottom:6px;">
      <input id="ed-username" type="text" maxlength="20" value={@current_user && @current_user.username} style="flex:1; padding:13px 16px; border:1.5px solid #e0e0e0; border-radius:16px; font-family:Poppins,sans-serif; font-size:14px; color:#333; outline:none; box-sizing:border-box;"/>
      <button onclick="guardarUsernameEditor()" style="background:#186904; color:#fff; border:none; border-radius:16px; padding:0 20px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">Guardar</button>
    </div>
    <p id="ed-username-error" style="font-size:11px; color:#c0392b; margin:0 0 4px; font-family:Poppins,sans-serif; display:none;"></p>
    <p style="font-size:10px; color:#aaa; margin:0 0 22px; font-family:Poppins,sans-serif;">4-20 caracteres. Podés cambiarlo 1 vez cada 7 días.</p>

    <p style="font-size:13px; font-weight:600; color:#186904; margin:0 0 8px; font-family:Poppins,sans-serif;">Género</p>
    <div style="display:flex; gap:8px; margin-bottom:22px;">
      <div onclick="elegirGenero(this,'hombre')" data-gen="hombre" style="flex:1; display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 0; border:2px solid #e0e0e0; border-radius:16px; cursor:pointer; transition:all 0.2s;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2196F3" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="14" r="5"/><line x1="19" y1="5" x2="13.6" y2="10.4"/><polyline points="15 5 19 5 19 9"/></svg>
        <span style="font-size:12px; color:#555; font-family:Poppins,sans-serif;">Hombre</span>
      </div>
      <div onclick="elegirGenero(this,'mujer')" data-gen="mujer" style="flex:1; display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 0; border:2px solid #e0e0e0; border-radius:16px; cursor:pointer; transition:all 0.2s;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#E91E8C" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><line x1="12" y1="13" x2="12" y2="21"/><line x1="9" y1="18" x2="15" y2="18"/></svg>
        <span style="font-size:12px; color:#555; font-family:Poppins,sans-serif;">Mujer</span>
      </div>
      <div onclick="elegirGenero(this,'otro')" data-gen="otro" style="flex:1; display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 0; border:2px solid #e0e0e0; border-radius:16px; cursor:pointer; transition:all 0.2s;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/></svg>
        <span style="font-size:12px; color:#555; font-family:Poppins,sans-serif;">Prefiero no decir</span>
      </div>
    </div>

    <p style="font-size:13px; font-weight:600; color:#186904; margin:0 0 8px; font-family:Poppins,sans-serif;">Gmail</p>
    <input id="ed-gmail" type="email" value={@current_user && @current_user.email} readonly style="width:100%; padding:13px 16px; border:1.5px solid #e0e0e0; border-radius:16px; font-family:Poppins,sans-serif; font-size:14px; color:#999; background:#f7f7f7; outline:none; box-sizing:border-box; margin-bottom:22px; cursor:not-allowed;"/>

    <p style="font-size:13px; font-weight:600; color:#186904; margin:0 0 8px; font-family:Poppins,sans-serif;">Número de teléfono</p>
    <div style="display:flex; align-items:center; border:1.5px solid #e0e0e0; border-radius:16px; padding:0 16px; margin-bottom:10px;">
      <span style="font-size:14px; color:#555; font-family:Poppins,sans-serif; font-weight:600; padding-right:8px; border-right:1px solid #e0e0e0;">+54</span>
      <input id="ed-telefono" type="tel" placeholder="11 1234 5678" oninput="marcarCambio()" style="flex:1; padding:13px 0 13px 12px; border:none; font-family:Poppins,sans-serif; font-size:14px; color:#333; outline:none;"/>
    </div>

    <div style="height:1px; background:#eee; margin:24px 0;"></div>
    <p style="font-size:16px; font-weight:700; color:#111; margin:0 0 16px; font-family:Poppins,sans-serif;">Colores del perfil</p>

    <div id="color-preview" style={"--c-principal:#{c_pri}; --c-secundario:#{c_sec}; --c-numerico:#{c_numm}; --c-boton:#{c_bot}; margin-top:24px; margin-bottom:-30px; transform:scale(0.82); transform-origin:top center;"}>
      <div style="position:relative; background:var(--c-secundario); border-radius:90px; width:100%; height:300px;">
        <div style="position:absolute; z-index:10; top:15px; left:7px; width:155px; height:155px; border-radius:50%; overflow:hidden; border:4px solid var(--c-secundario); background:#f0f0f0;">
          <%= if @current_user && @current_user.avatar do %><img src={@current_user.avatar} style="width:100%; height:100%; object-fit:cover; display:block;"/><% else %><div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:40px;">👤</div><% end %>
        </div>
        <div style="position:absolute; top:45px; left:180px; right:30px; height:90px; background:var(--c-principal); border-radius:70px; display:flex; flex-direction:column; align-items:flex-start; justify-content:center; gap:8px; padding:0 25px; box-sizing:border-box;">
          <span style="font-size:16px; font-weight:600; color:#000; font-family:Poppins,sans-serif; max-width:100%; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@<%= @current_user && @current_user.username %></span>
          <div style="display:flex; gap:8px; margin-left:-12px; margin-top:-4px;">
            <button style="background:var(--c-secundario); color:var(--c-boton); border:none; border-radius:12px; padding:6px 14px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; white-space:nowrap;">Seguir</button>
            <button style="background:var(--c-secundario); color:var(--c-boton); border:none; border-radius:12px; padding:6px 14px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; white-space:nowrap;">Mensaje</button>
          </div>
        </div>
        <div style="position:absolute; top:160px; left:30px; right:30px; height:120px; background:var(--c-principal); border-radius:50px;"></div>
      </div>
      <div style="background:var(--c-secundario); border-radius:40px; width:100%; margin-top:16px; padding:10px; box-sizing:border-box; display:flex; gap:10px;">
        <div style="flex:1; background:var(--c-principal); border-radius:50px; padding:9px 0; text-align:center;"><p style="margin:0; font-size:22px; font-weight:700; color:var(--c-numerico); font-family:Poppins,sans-serif;">3</p><p style="margin:2px 0 0; font-size:11px; color:#888; font-family:Poppins,sans-serif;">Seguidores</p></div>
        <div style="flex:1; background:var(--c-principal); border-radius:50px; padding:9px 0; text-align:center;"><p style="margin:0; font-size:22px; font-weight:700; color:var(--c-numerico); font-family:Poppins,sans-serif;">3</p><p style="margin:2px 0 0; font-size:11px; color:#888; font-family:Poppins,sans-serif;">Seguidos</p></div>
        <div style="flex:1; background:var(--c-principal); border-radius:50px; padding:9px 0; text-align:center;"><p style="margin:0; font-size:22px; font-weight:700; color:var(--c-numerico); font-family:Poppins,sans-serif;">0</p><p style="margin:2px 0 0; font-size:11px; color:#888; font-family:Poppins,sans-serif;">Publicaciones</p></div>
      </div>
    </div>

    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid #f2f2f2;">
      <span style="font-size:14px; color:#333; font-family:Poppins,sans-serif;">Color principal</span>
      <div style={"width:34px; height:34px; border-radius:50%; border:2px solid #e0e0e0; position:relative; overflow:hidden; background:#{c_pri};"}><input type="color" value={c_pri} oninput="setColorPreview('--c-principal', this)" style="position:absolute; top:-8px; left:-8px; width:50px; height:50px; border:none; padding:0; cursor:pointer;"></div>
    </div>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid #f2f2f2;">
      <span style="font-size:14px; color:#333; font-family:Poppins,sans-serif;">Color secundario</span>
      <div style={"width:34px; height:34px; border-radius:50%; border:2px solid #e0e0e0; position:relative; overflow:hidden; background:#{c_sec};"}><input type="color" value={c_sec} oninput="setColorPreview('--c-secundario', this)" style="position:absolute; top:-8px; left:-8px; width:50px; height:50px; border:none; padding:0; cursor:pointer;"></div>
    </div>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid #f2f2f2;">
      <span style="font-size:14px; color:#333; font-family:Poppins,sans-serif;">Color de números</span>
      <div style={"width:34px; height:34px; border-radius:50%; border:2px solid #e0e0e0; position:relative; overflow:hidden; background:#{c_numm};"}><input type="color" value={c_numm} oninput="setColorPreview('--c-numerico', this)" style="position:absolute; top:-8px; left:-8px; width:50px; height:50px; border:none; padding:0; cursor:pointer;"></div>
    </div>
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid #f2f2f2;">
      <span style="font-size:14px; color:#333; font-family:Poppins,sans-serif;">Color de botones</span>
      <div style={"width:34px; height:34px; border-radius:50%; border:2px solid #e0e0e0; position:relative; overflow:hidden; background:#{c_bot};"}><input type="color" value={c_bot} oninput="setColorPreview('--c-boton', this)" style="position:absolute; top:-8px; left:-8px; width:50px; height:50px; border:none; padding:0; cursor:pointer;"></div>
    </div>

    <button onclick="guardarColores()" style="width:100%; background:#186904; color:#fff; border:none; border-radius:16px; padding:14px 0; font-size:15px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; margin-top:20px;">Guardar cambios</button>
    <button onclick="document.getElementById('aviso-reset').style.display='flex'" style="width:100%; background:#fff; color:#186904; border:2px solid #186904; border-radius:16px; padding:12px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; margin-top:10px; display:flex; align-items:center; justify-content:center; gap:8px;">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#186904" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
      Predeterminado
    </button>

    <button onclick="guardarDatosEditor()" style="display:none; width:100%; background:#186904; color:#fff; border:none; border-radius:16px; padding:15px 0; font-size:15px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; margin-top:14px;">Guardar cambios</button>
  </div>
</div>

<script>
  function abrirEditor() {
    document.getElementById('editor-overlay').style.transform = 'translateY(0)';
  }
  function cerrarEditor() {
    document.getElementById('editor-overlay').style.transform = 'translateY(100%)';
  }
  function elegirGenero(el, genero) {
    document.querySelectorAll('[data-gen]').forEach(function(b) {
      b.style.borderColor = '#e0e0e0';
      b.style.background = '#fff';
    });
    el.style.borderColor = '#186904';
    el.style.background = '#E8F5EC';
    fetch('/perfil/config', {
      method: 'POST',
      headers: { 'x-csrf-token': csrfTokenPerfil, 'content-type': 'application/json' },
      body: JSON.stringify({ config: { genero: genero } })
    }).then(r => r.json()).then(function(data) {
      if (data.ok) { window.mostrarAviso && window.mostrarAviso('Género guardado'); }
    });
  }
  // Colores seleccionados en el editor
  var coloresEditor = { principal: <%= raw(Jason.encode!(c_pri)) %>, secundario: <%= raw(Jason.encode!(c_sec)) %>, numerico: <%= raw(Jason.encode!(c_numm)) %>, boton: <%= raw(Jason.encode!(c_bot)) %> };
  function setColorPreview(varName, input) {
    marcarCambio();
    document.getElementById('color-preview').style.setProperty(varName, input.value);
    input.parentElement.style.background = input.value;
    if (varName === '--c-principal') coloresEditor.principal = input.value;
    if (varName === '--c-secundario') coloresEditor.secundario = input.value;
    if (varName === '--c-numerico') coloresEditor.numerico = input.value;
    if (varName === '--c-boton') coloresEditor.boton = input.value;
  }
  function resetColores() {
    coloresEditor = { principal:"#ffffff", secundario:"#186904", numerico:"#000000", boton:"#ffffff" };
    var pv = document.getElementById('color-preview');
    pv.style.setProperty('--c-principal', '#ffffff');
    pv.style.setProperty('--c-secundario', '#186904');
    pv.style.setProperty('--c-numerico', '#000000');
    pv.style.setProperty('--c-boton', '#ffffff');
    document.querySelectorAll('input[type=color]').forEach(function(inp) {
      var v = inp.getAttribute('oninput');
      if (v.indexOf('principal') > -1) { inp.value = '#ffffff'; inp.parentElement.style.background = '#ffffff'; }
      if (v.indexOf('secundario') > -1) { inp.value = '#186904'; inp.parentElement.style.background = '#186904'; }
      if (v.indexOf('numerico') > -1) { inp.value = '#000000'; inp.parentElement.style.background = '#000000'; }
      if (v.indexOf('boton') > -1) { inp.value = '#ffffff'; inp.parentElement.style.background = '#ffffff'; }
    });
  }
  function guardarUsernameEditor() {
    var nuevo = document.getElementById('ed-username').value.trim();
    var errEl = document.getElementById('ed-username-error');
    fetch('/perfil/username', {
      method: 'POST',
      headers: { 'x-csrf-token': csrfTokenPerfil, 'content-type': 'application/json' },
      body: JSON.stringify({ username: nuevo })
    }).then(r => r.json()).then(function(data) {
      if (data.ok) {
        errEl.style.display = 'none';
        window.mostrarAviso && window.mostrarAviso('Nombre guardado');
      } else {
        errEl.textContent = data.error;
        errEl.style.display = 'block';
      }
    });
  }
  function guardarColores() {
    var tel = document.getElementById('ed-telefono').value.trim();
    fetch('/perfil/config', {
      method: 'POST',
      headers: { 'x-csrf-token': csrfTokenPerfil, 'content-type': 'application/json' },
      body: JSON.stringify({ config: {
        principal: coloresEditor.principal,
        secundario: coloresEditor.secundario,
        numerico: coloresEditor.numerico,
        boton: coloresEditor.boton,
        telefono: tel
      } })
    }).then(r => r.json()).then(function(data) {
      if (data.ok) {
        window.mostrarAviso && window.mostrarAviso('Cambios guardados');
        setTimeout(function(){ location.reload(); }, 600);
      } else {
        mostrarError(guardarColores);
      }
    }).catch(function(){ mostrarError(guardarColores); });
  }
</script>

<!-- AVISO DE ERROR GENERAL -->
<div id="aviso-error" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.45); z-index:6002; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:28px; width:300px; max-width:85%; padding:28px 24px 22px; box-shadow:0 12px 40px rgba(0,0,0,0.25); text-align:center;">
    <div style="width:64px; height:64px; margin:0 auto 14px; border:4px solid #186904; border-radius:50%; display:flex; align-items:center; justify-content:center;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none"><line x1="12" y1="7" x2="12" y2="14" stroke="#186904" stroke-width="3.5" stroke-linecap="round"/><circle cx="12" cy="18.5" r="1.8" fill="#186904"/></svg>
    </div>
    <p style="font-size:20px; font-weight:700; color:#186904; margin:0 0 12px; font-family:Poppins,sans-serif;">Algo salió mal</p>
    <div style="height:2px; width:60px; background:#186904; border-radius:2px; margin:0 auto 14px;"></div>
    <p style="font-size:14px; color:#555; margin:0 0 22px; line-height:1.4; font-family:Poppins,sans-serif;">Intentá nuevamente más tarde. Si sigue sucediendo, considerá contactar a soporte.</p>
    <div style="display:flex; gap:10px;">
      <button onclick="reintentarError()" style="flex:1; background:#186904; color:#fff; border:none; border-radius:14px; padding:13px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">Reintentar</button>
      <button onclick="document.getElementById('aviso-error').style.display='none'" style="flex:1; background:#fff; color:#186904; border:2px solid #186904; border-radius:14px; padding:11px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">Cerrar</button>
    </div>
  </div>
</div>

<!-- AVISO CONFIRMAR PREDETERMINADO -->
<div id="aviso-reset" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.45); z-index:6001; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:28px; width:300px; max-width:85%; padding:28px 24px 22px; box-shadow:0 12px 40px rgba(0,0,0,0.25); text-align:center;">
    <div style="width:64px; height:64px; margin:0 auto 14px; border:4px solid #186904; border-radius:50%; display:flex; align-items:center; justify-content:center;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none"><line x1="12" y1="7" x2="12" y2="14" stroke="#186904" stroke-width="3.5" stroke-linecap="round"/><circle cx="12" cy="18.5" r="1.8" fill="#186904"/></svg>
    </div>
    <p style="font-size:20px; font-weight:700; color:#186904; margin:0 0 12px; font-family:Poppins,sans-serif;">Aviso</p>
    <div style="height:2px; width:60px; background:#186904; border-radius:2px; margin:0 auto 14px;"></div>
    <p style="font-size:14px; color:#555; margin:0 0 22px; line-height:1.4; font-family:Poppins,sans-serif;">¿Estás seguro de volver a los valores predeterminados? Todos los cambios de color volverán al original.</p>
    <div style="display:flex; gap:10px;">
      <button onclick="confirmarReset()" style="flex:1; background:#186904; color:#fff; border:none; border-radius:14px; padding:13px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">Sí</button>
      <button onclick="document.getElementById('aviso-reset').style.display='none'" style="flex:1; background:#fff; color:#186904; border:2px solid #186904; border-radius:14px; padding:11px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">No</button>
    </div>
  </div>
</div>

<!-- AVISO CAMBIOS SIN GUARDAR -->
<div id="aviso-cambios" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.45); z-index:6000; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:28px; width:300px; max-width:85%; padding:28px 24px 22px; box-shadow:0 12px 40px rgba(0,0,0,0.25); text-align:center;">
    <div style="width:64px; height:64px; margin:0 auto 14px; border:4px solid #186904; border-radius:50%; display:flex; align-items:center; justify-content:center;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none"><line x1="12" y1="7" x2="12" y2="14" stroke="#186904" stroke-width="3.5" stroke-linecap="round"/><circle cx="12" cy="18.5" r="1.8" fill="#186904"/></svg>
    </div>
    <p style="font-size:20px; font-weight:700; color:#186904; margin:0 0 12px; font-family:Poppins,sans-serif;">Aviso</p>
    <div style="height:2px; width:60px; background:#186904; border-radius:2px; margin:0 auto 14px;"></div>
    <p style="font-size:14px; color:#555; margin:0 0 22px; line-height:1.4; font-family:Poppins,sans-serif;">Hiciste cambios que todavía no guardaste. ¿Querés guardarlos antes de salir?</p>
    <div style="display:flex; flex-direction:column; gap:10px;">
      <button onclick="guardarColores()" style="background:#186904; color:#fff; border:none; border-radius:14px; padding:13px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">Guardar cambios</button>
      <button onclick="salirSinGuardar()" style="background:#fff; color:#186904; border:2px solid #186904; border-radius:14px; padding:11px 0; font-size:14px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer;">Salir sin guardar</button>
    </div>
  </div>
</div>

<script>
  var hayCambios = false;
  function marcarCambio() { hayCambios = true; }
  function intentarCerrarEditor() {
    if (hayCambios) {
      document.getElementById('aviso-cambios').style.display = 'flex';
      var ov = document.getElementById('editor-overlay');
      ov.scrollTo({ top: ov.scrollHeight, behavior: 'smooth' });
    } else {
      cerrarEditor();
    }
  }
  function salirSinGuardar() {
    hayCambios = false;
    document.getElementById('aviso-cambios').style.display = 'none';
    cerrarEditor();
  }
  function confirmarReset() {
    document.getElementById('aviso-reset').style.display = 'none';
    resetColores();
    hayCambios = false;
    fetch('/perfil/config', {
      method: 'POST',
      headers: { 'x-csrf-token': csrfTokenPerfil, 'content-type': 'application/json' },
      body: JSON.stringify({ config: {
        principal: "#ffffff",
        secundario: "#186904",
        numerico: "#000000",
        boton: "#ffffff"
      } })
    }).then(r => r.json()).then(function(data) {
      if (data.ok) {
        window.mostrarAviso && window.mostrarAviso('Colores restablecidos');
        setTimeout(function(){ location.reload(); }, 600);
      }
    });
  }
  var ultimaAccionError = null;
  function mostrarError(accionReintentar) {
    ultimaAccionError = accionReintentar || null;
    document.getElementById('aviso-error').style.display = 'flex';
  }
  function reintentarError() {
    document.getElementById('aviso-error').style.display = 'none';
    if (typeof ultimaAccionError === 'function') ultimaAccionError();
  }
</script>

<script>
  (function(){
    var pts=0; var MAX=5000; var nivs=[1000,2000,3500,5000]; var MULT=1;
    var nivelPrev=1;
    // mapea puntos a la altura del liquido para que coincida con las lineas
    // lineas: 1000->15%, 2000->40%, 3500->65%, 5000->88%
    function dpAltura(p){
      var puntos=[0,1000,2000,3500,5000];
      var alturas=[0,15,40,65,88];
      if(p>=5000) return 88;
      for(var i=1;i<puntos.length;i++){
        if(p<=puntos[i]){
          var t=(p-puntos[i-1])/(puntos[i]-puntos[i-1]);
          return alturas[i-1]+t*(alturas[i]-alturas[i-1]);
        }
      }
      return 88;
    }
    function nivelDe(p){ var n=0; nivs.forEach(function(u){if(p>=u)n++;}); return n===0?1:n; }
    function render(){
      var liq=document.getElementById('dp-liquido');
      var txt=document.getElementById('dp-niveltxt');
      if(liq) liq.style.height=dpAltura(pts)+'%';
      var n=nivelDe(pts);
      if(txt) txt.textContent=pts+' pts · Nivel '+n;
      if(n>nivelPrev) festejarNivel(n);
      nivelPrev=n;
    }
    function festejarNivel(n){
      var f=document.getElementById('dp-festejo');
      if(f){ f.textContent='¡Nivel '+n+'! 🎉'; f.classList.remove('dp-show'); void f.offsetWidth; f.classList.add('dp-show'); }
      var m=document.getElementById('dp-m'+(n-1));
      if(m){ m.classList.add('dp-flash'); setTimeout(function(){m.classList.remove('dp-flash');},900); }
    }
    function spawnBurbuja(){
      var liq=document.getElementById('dp-liquido');
      if(!liq || liq.offsetHeight<20) return;
      var b=document.createElement('div'); var sz=3+Math.random()*4;
      b.className='dp-burbuja';
      b.style.width=sz+'px'; b.style.height=sz+'px';
      b.style.left=(10+Math.random()*60)+'px';
      b.style.animationDuration=(1.5+Math.random()*1.5)+'s';
      liq.appendChild(b);
      setTimeout(function(){b.remove();},3000);
    }
    setInterval(spawnBurbuja,500);

    window.dpAdd=function(){ pts=Math.min(MAX,pts+250); render(); };
    window.dpSub=function(){ pts=Math.max(0,pts-250); render(); };
    window.dpCupon=function(){
      var t=document.getElementById('dp-tritu'); var zona=t.parentElement;
      t.classList.add('dp-muerde','dp-girando');
      for(var i=0;i<3;i++){(function(i){ setTimeout(function(){
        var g=document.createElement('div');
        g.style.cssText='position:absolute;left:'+(40+i*7)+'px;top:78px;width:9px;height:12px;background:#27A04C;border-radius:50%/60% 60% 40% 40%;z-index:4;';
        zona.appendChild(g);
        var y=78,v=0;
        var fall=setInterval(function(){ v+=1.2; y+=v; g.style.top=y+'px';
          if(y>335){ v=-v*0.4; y=335; if(Math.abs(v)<2){clearInterval(fall); g.style.transition='opacity 0.3s'; g.style.opacity=0; setTimeout(function(){g.remove();},300);} }
        },16);
      }, i*160); })(i);}
      setTimeout(function(){ t.classList.remove('dp-muerde','dp-girando'); pts=Math.min(MAX,pts+Math.round(100*MULT)); render(); },1300);
    };

    var tubo=document.getElementById('dp-tubo');
    if(tubo){
      function dpSet(cy){
        var r=tubo.getBoundingClientRect();
        var pct=1-(cy-r.top)/r.height; pct=Math.max(0,Math.min(1,pct));
        pts=Math.round(pct*MAX); render();
      }
      var drag=false;
      tubo.addEventListener('mousedown',function(e){drag=true;dpSet(e.clientY);});
      window.addEventListener('mousemove',function(e){if(drag)dpSet(e.clientY);});
      window.addEventListener('mouseup',function(){drag=false;});
      tubo.addEventListener('touchstart',function(e){dpSet(e.touches[0].clientY);});
      tubo.addEventListener('touchmove',function(e){dpSet(e.touches[0].clientY); e.preventDefault();},{passive:false});
    }
    render();
  })();
</script>

