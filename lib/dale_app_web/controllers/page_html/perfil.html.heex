          <div class="dp-marca-l" id="dp-m0" style="position:absolute; right:0; bottom:15%; width:14px; height:3px; background:#333; z-index:4;"></div><div style="position:absolute; right:18px; bottom:15%; font-size:9px; color:#555; transform:translateY(-7px); z-index:4;">1000</div>
          <div class="dp-marca-l" id="dp-m1" style="position:absolute; right:0; bottom:40%; width:14px; height:3px; background:#333; z-index:4;"></div><div style="position:absolute; right:18px; bottom:40%; font-size:9px; color:#555; transform:translateY(-7px); z-index:4;">2000</div>
          <div class="dp-marca-l" id="dp-m2" style="position:absolute; right:0; bottom:65%; width:14px; height:3px; background:#333; z-index:4;"></div><div style="position:absolute; right:18px; bottom:65%; font-size:9px; color:#555; transform:translateY(-7px); z-index:4;">3500</div>
          <div class="dp-marca-l" id="dp-m3" style="position:absolute; right:0; bottom:88%; width:14px; height:3px; background:#333; z-index:4;"></div><div style="position:absolute; right:18px; bottom:88%; font-size:9px; color:#555; transform:translateY(-7px); z-index:4;">5000</div>
        </div>
