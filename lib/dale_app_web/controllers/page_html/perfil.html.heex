        <div class="dp-nivel" onclick="dpToggleNivel(1)" style="border:2px solid #e8e8e8; border-radius:16px; padding:14px 16px; cursor:pointer; background:#fff;">
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:15px; font-weight:700; color:#000; font-family:Poppins,sans-serif;">Nivel 1 · 1000</span>
