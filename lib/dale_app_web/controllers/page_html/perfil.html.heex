        <div id="dp-tubo" style="position:relative; width:90px; height:330px; margin:-2px auto 0; border:4px solid #0A0A0A; border-top:none; border-radius:0 0 45px 45px; background:linear-gradient(to right, rgba(255,255,255,0.85), rgba(220,235,222,0.35) 45%, rgba(150,180,155,0.4)); overflow:hidden; box-sizing:border-box;">
          <div id="dp-liquido" style="position:absolute; left:0; right:0; bottom:0; height:0%; background:linear-gradient(#6BDB88,#27A04C); transition:height 0.7s cubic-bezier(0.34,1.3,0.5,1); border-radius:0 0 41px 41px;">
            <div style="position:absolute; top:-11px; left:0; width:200%; height:13px;">
              <svg viewBox="0 0 200 13" preserveAspectRatio="none" style="width:100%; height:100%; display:block; animation:dp-ondular 2s linear infinite;"><path d="M0,6 Q25,0 50,6 T100,6 T150,6 T200,6 V13 H0 Z" fill="#6BDB88"/></svg>
            </div>
