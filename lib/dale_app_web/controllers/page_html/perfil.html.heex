<style>
  @keyframes dp-ondular { to{transform:translateX(-50%)} }
  @keyframes dp-respirar { 0%,100%{transform:scale(1) rotate(0)} 50%{transform:scale(1.04,0.97) rotate(-0.5deg)} }
  @keyframes dp-morder { 0%,100%{transform:translateX(0) scale(1)} 25%{transform:translateX(-3px) scale(1.05,0.95)} 75%{transform:translateX(3px) scale(0.97,1.04)} }
  @keyframes dp-gIzq { to{transform:rotate(-360deg)} }
  @keyframes dp-gDer { to{transform:rotate(360deg)} }
  @keyframes dp-parpadeo { 0%,92%,100%{transform:scaleY(1)} 96%{transform:scaleY(0.1)} }
  @keyframes dp-vaiven { 0%,100%{transform:rotate(0)} 50%{transform:rotate(0.4deg)} }
  @keyframes dp-subir { 0%{transform:translateY(0); opacity:0.8} 100%{transform:translateY(-300px); opacity:0} }
  @keyframes dp-festejar { 0%{opacity:0; transform:translate(-50%,10px) scale(0.8)} 30%{opacity:1; transform:translate(-50%,-8px) scale(1.1)} 100%{opacity:0; transform:translate(-50%,-30px) scale(1)} }
  #dp-tritu { transform-origin:center bottom; animation: dp-respirar 2.6s ease-in-out infinite; }
  #dp-tritu.dp-muerde { animation: dp-morder 0.35s ease-in-out infinite; }
  #dp-tritu .dp-rodillo { transform-box:fill-box; transform-origin:center; }
  #dp-tritu.dp-girando .dp-rod-izq { animation: dp-gIzq 0.35s linear infinite; }
  #dp-tritu.dp-girando .dp-rod-der { animation: dp-gDer 0.35s linear infinite; }
  #dp-tritu .dp-ojo { animation: dp-parpadeo 4s infinite; transform-origin:center; }
  #dp-liquido { animation: dp-vaiven 3.5s ease-in-out infinite; }
  .dp-burbuja { position:absolute; background:rgba(255,255,255,0.6); border-radius:50%; bottom:0; z-index:2; animation: dp-subir linear infinite; }
  .dp-marca-l { transition:background 0.2s; }
  .dp-marca-l.dp-flash { background:#FFD200 !important; box-shadow:0 0 8px #FFD200; }
  #dp-festejo { position:absolute; left:50%; top:38%; transform:translateX(-50%); font-size:13px; font-weight:700; color:#186904; opacity:0; pointer-events:none; z-index:10; white-space:nowrap; font-family:Poppins,sans-serif; }
  #dp-festejo.dp-show { animation: dp-festejar 1.2s ease-out; }
</style>
<style>
  #perfil-slider { display:flex; width:100%; height:calc(100vh - 60px); overflow-x:auto; overflow-y:hidden; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; scrollbar-width:none; }
  #perfil-slider::-webkit-scrollbar { display:none; }
  .perfil-panel { flex:0 0 100%; width:100%; height:100%; overflow-y:auto; scroll-snap-align:start; scroll-snap-stop:always; box-sizing:border-box; }
  .perfil-dot { width:7px; height:7px; border-radius:50%; background:#ccc; transition:all 0.25s; }
  .perfil-dot.activo { background:#186904; width:18px; border-radius:4px; }
</style>

<div style="position:fixed; top:60px; left:0; right:0; z-index:50; display:flex; justify-content:center; gap:6px; padding:10px 0; pointer-events:none;">
  <div class="perfil-dot" id="pdot-0"></div>
  <div class="perfil-dot activo" id="pdot-1"></div>
  <div class="perfil-dot" id="pdot-2"></div>
</div>

<div id="perfil-slider">

  <!-- PANEL 1 (izquierda): perfil actual -->
  <div class="perfil-panel" style="padding:0 16px;">
  <%= if @current_user do %>
    <% cfg = @current_user.perfil_config || %{} %>
    <% forma = Map.get(cfg, "forma", "capsula") %>
    <% c_principal = Map.get(cfg, "principal", "#ffffff") %>
    <% c_secundario = Map.get(cfg, "secundario", "#186904") %>
    <% c_numerico = Map.get(cfg, "numerico", forma == "capsula" && "#ffffff" || "#186904") %>
    <% c_boton = Map.get(cfg, "boton", forma == "capsula" && "#186904" || "#ffffff") %>

    <div id="perfil-header" style={"margin-top:24px; --c-principal:#{c_principal}; --c-secundario:#{c_secundario}; --c-numerico:#{c_numerico}; --c-boton:#{c_boton};"}>

      <%= if forma == "capsula" do %>
        <!-- FORMA 1: CAPSULA -->
        <div style="background:var(--c-secundario); border-radius:34px; padding:18px; display:flex; align-items:center; gap:14px;">
          <div style="position:relative; width:84px; height:84px; flex-shrink:0; cursor:pointer;" onclick="document.getElementById('foto-input').click()">
            <%= if @current_user.avatar do %>
              <img src={@current_user.avatar} id="foto-preview" style="width:84px; height:84px; border-radius:50%; object-fit:cover; border:4px solid var(--c-principal); background:var(--c-principal);"/>
            <% else %>
              <div id="foto-preview" style="width:84px; height:84px; border-radius:50%; background:var(--c-principal); border:4px solid var(--c-principal); display:flex; align-items:center; justify-content:center; font-size:32px;">👤</div>
            <% end %>
          </div>
          <div style="flex:1; min-width:0;">
            <p style="margin:0 0 8px; font-size:14px; font-weight:700; color:var(--c-secundario); background:var(--c-principal); display:inline-block; padding:4px 12px; border-radius:14px; font-family:'Noto Sans',sans-serif; max-width:100%; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@<%= @current_user.username %></p>
            <div style="display:flex; gap:8px;">
              <button style="background:var(--c-principal); color:var(--c-boton); border:none; border-radius:14px; padding:7px 18px; font-size:13px; font-weight:700; font-family:'Noto Sans',sans-serif; cursor:pointer;">Seguir</button>
              <button style="background:var(--c-principal); color:var(--c-boton); border:none; border-radius:14px; padding:7px 18px; font-size:13px; font-weight:700; font-family:'Noto Sans',sans-serif; cursor:pointer;">Mensaje</button>
            </div>
          </div>
        </div>
        <div style="display:flex; gap:10px; margin-top:12px;">
          <div style="flex:1; background:var(--c-secundario); border-radius:20px; padding:10px 0; text-align:center;">
            <p style="margin:0; font-size:20px; font-weight:700; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;"><%= length(@amigos) %></p>
            <p style="margin:2px 0 0; font-size:11px; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;">Seguidores</p>
          </div>
          <div style="flex:1; background:var(--c-secundario); border-radius:20px; padding:10px 0; text-align:center;">
            <p style="margin:0; font-size:20px; font-weight:700; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;"><%= length(@amigos) %></p>
            <p style="margin:2px 0 0; font-size:11px; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;">Seguidos</p>
          </div>
          <div style="flex:1; background:var(--c-secundario); border-radius:20px; padding:10px 0; text-align:center;">
            <p style="margin:0; font-size:20px; font-weight:700; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;"><%= length(@favoritos) %></p>
            <p style="margin:2px 0 0; font-size:11px; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;">Publicaciones</p>
          </div>
        </div>

      <% else %>
        <!-- FORMA 2: TARJETA -->
        <div style="background:var(--c-principal); border:2px solid var(--c-secundario); border-radius:24px; padding:18px;">
          <div style="display:flex; align-items:center; gap:14px;">
            <div style="position:relative; width:88px; height:88px; flex-shrink:0; cursor:pointer;" onclick="document.getElementById('foto-input').click()">
              <%= if @current_user.avatar do %>
                <img src={@current_user.avatar} id="foto-preview" style="width:88px; height:88px; border-radius:50%; object-fit:cover; border:3px solid var(--c-secundario);"/>
              <% else %>
                <div id="foto-preview" style="width:88px; height:88px; border-radius:50%; background:#f0f0f0; border:3px solid var(--c-secundario); display:flex; align-items:center; justify-content:center; font-size:32px;">👤</div>
              <% end %>
            </div>
            <div style="flex:1; min-width:0;">
              <p style="margin:0 0 8px; font-size:15px; font-weight:700; color:var(--c-secundario); font-family:'Noto Sans',sans-serif; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@<%= @current_user.username %></p>
              <div style="display:flex; gap:8px;">
                <button style="background:var(--c-secundario); color:var(--c-boton); border:none; border-radius:8px; padding:7px 18px; font-size:13px; font-weight:700; font-family:'Noto Sans',sans-serif; cursor:pointer;">Seguir</button>
                <button style="background:var(--c-secundario); color:var(--c-boton); border:none; border-radius:8px; padding:7px 18px; font-size:13px; font-weight:700; font-family:'Noto Sans',sans-serif; cursor:pointer;">Mensaje</button>
              </div>
            </div>
          </div>
        </div>
        <div style="display:flex; gap:10px; margin-top:12px;">
          <div style="flex:1; background:var(--c-principal); border:2px solid var(--c-secundario); border-radius:18px; padding:9px 0; text-align:center;">
            <p style="margin:0; font-size:19px; font-weight:700; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;"><%= length(@amigos) %></p>
            <p style="margin:2px 0 0; font-size:11px; color:#999; font-family:'Noto Sans',sans-serif;">Seguidores</p>
          </div>
          <div style="flex:1; background:var(--c-principal); border:2px solid var(--c-secundario); border-radius:18px; padding:9px 0; text-align:center;">
            <p style="margin:0; font-size:19px; font-weight:700; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;"><%= length(@amigos) %></p>
            <p style="margin:2px 0 0; font-size:11px; color:#999; font-family:'Noto Sans',sans-serif;">Seguidos</p>
          </div>
          <div style="flex:1; background:var(--c-principal); border:2px solid var(--c-secundario); border-radius:18px; padding:9px 0; text-align:center;">
            <p style="margin:0; font-size:19px; font-weight:700; color:var(--c-numerico); font-family:'Noto Sans',sans-serif;"><%= length(@favoritos) %></p>
            <p style="margin:2px 0 0; font-size:11px; color:#999; font-family:'Noto Sans',sans-serif;">Publicaciones</p>
          </div>
        </div>
      <% end %>

      <input type="file" id="foto-input" accept="image/*" style="display: none;" onchange="subirFotoPerfil(this)"/>
    </div>

    <div style="margin-top: 24px; display: flex; justify-content: center;">
      <button onclick="abrirSelectorFotos()" style="display: flex; align-items: center; gap: 8px; padding: 10px 24px; border: 1.5px solid #186904; border-radius: 20px; background: white; color: #186904; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'Noto Sans', sans-serif;">
        <span style="font-size: 16px;">📸</span> Subir foto
      </button>
    </div>

    <div style="margin-top: 32px; padding: 14px; background: #f7f7f7; border-radius: 10px;">
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <div>
          <p style="font-size: 11px; color: #999; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 1px; font-family: 'Noto Sans', sans-serif;">Tu usuario</p>
          <p id="username-display" style="font-size: 16px; font-weight: 700; color: #186904; margin: 0; font-family: 'Noto Sans', sans-serif;"><%= @current_user.username %></p>
        </div>
        <button onclick="abrirEditorUsername()" style="padding: 6px 14px; border: 1.5px solid #186904; border-radius: 16px; background: white; color: #186904; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'Noto Sans', sans-serif;">Cambiar</button>
      </div>
      <div id="editor-username" style="display: none; margin-top: 12px;">
        <div style="display: flex; gap: 8px;">
          <input id="nuevo-username" type="text" placeholder="Nuevo nombre" maxlength="20" style="flex: 1; padding: 8px; border: 1px solid #ccc; border-radius: 6px; font-family: 'Noto Sans', sans-serif; font-size: 13px;"/>
          <button onclick="guardarUsername()" style="padding: 8px 14px; border: none; border-radius: 6px; background: #186904; color: white; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'Noto Sans', sans-serif;">Guardar</button>
        </div>
        <p id="username-error" style="font-size: 12px; color: #c0392b; margin: 6px 0 0; font-family: 'Noto Sans', sans-serif; display: none;"></p>
        <p style="font-size: 11px; color: #999; margin: 6px 0 0; font-family: 'Noto Sans', sans-serif;">4-20 caracteres, solo letras, números y _. Los usuarios pueden cambiar su nombre 1 vez cada 7 días.</p>
      </div>
    </div>

    <div style="margin-top: 24px; margin-bottom: 40px;">
      <p style="font-size: 12px; font-weight: 600; color: #333; margin: 0 0 8px; text-transform: uppercase; letter-spacing: 1px; font-family: 'Noto Sans', sans-serif;">Tus amigos</p>
      <%= if @amigos == [] do %>
        <p style="font-size: 13px; color: #999; font-family: 'Noto Sans', sans-serif;">Todavía no agregaste amigos.</p>
      <% else %>
        <%= for a <- @amigos do %>
          <div style="padding: 10px 0; border-bottom: 1px solid #eee; font-size: 14px; font-family: 'Noto Sans', sans-serif; color: #111;">
            <%= a.username %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

  <% cfg2 = (@current_user && @current_user.perfil_config) || %{} %>
  <% c_sec = Map.get(cfg2, "secundario", "#186904") %>
  <% c_pri = Map.get(cfg2, "principal", "#ffffff") %>
  <% c_numm = Map.get(cfg2, "numerico", "#000000") %>
  <% c_bot = Map.get(cfg2, "boton", "#ffffff") %>
  <div class="perfil-panel" id="perfil-panel-centro" style={"padding:16px; --c-principal:#{c_pri}; --c-secundario:#{c_sec}; --c-numerico:#{c_numm}; --c-boton:#{c_bot};"}>
    <div style={"position:relative; background:#{c_sec}; border-radius:90px; width:100%; height: 300px;margin-top:20px;"}>
      <div style="position:absolute; z-index:10; top:15px; left:7px; width:155px; height:155px; border-radius:50%; overflow:hidden; border:4px solid var(--c-secundario,#186904); background:#f0f0f0;">
        <%= if @current_user && @current_user.avatar do %>
          <img src={@current_user.avatar} style="width:100%; height:100%; object-fit:cover; display:block;"/>
        <% else %>
          <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:40px;">👤</div>
        <% end %>
      </div>
      <div style="position:absolute; top:45px; left:180px; right:30px; height:90px; background:var(--c-principal,#fff); border-radius:70px; display:flex; flex-direction:column; align-items:flex-start; justify-content:center; gap:8px; padding:0 25px; box-sizing:border-box;"><span style="font-size:16px; font-weight:600; color:#000; font-family:Poppins,sans-serif; max-width:100%; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@<%= @current_user && @current_user.username %></span><div style="display:flex; gap:8px; margin-left:-12px; margin-top:-4px;"><%= if assigns[:es_dueno_perfil] != false do %><button onclick="abrirEditor()" style="background:var(--c-secundario,#186904); color:var(--c-boton,#fff); border:none; border-radius:12px; padding:6px 14px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; white-space:nowrap;">Editar</button><button onclick="abrirSelectorFotos()" style="background:var(--c-secundario,#186904); color:var(--c-boton,#fff); border:none; border-radius:12px; padding:6px 14px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; white-space:nowrap;">Publicar</button><% else %><button style="background:var(--c-secundario,#186904); color:var(--c-boton,#fff); border:none; border-radius:12px; padding:6px 14px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; white-space:nowrap;">Seguir</button><button style="background:var(--c-secundario,#186904); color:var(--c-boton,#fff); border:none; border-radius:12px; padding:6px 14px; font-size:13px; font-weight:600; font-family:Poppins,sans-serif; cursor:pointer; white-space:nowrap;">Mensaje</button><% end %></div></div>
      <% vitrina_url = Map.get(cfg2, "vitrina") %>
      <div onclick="abrirCropperVitrina()" style="position:absolute; top:160px; left:30px; right:30px; height:120px; background:var(--c-principal,#fff); border-radius:50px; overflow:hidden; cursor:pointer; display:flex; align-items:center; justify-content:center;">
        <%= if vitrina_url do %>
          <img id="vitrina-img" src={vitrina_url} style="width:100%; height:100%; object-fit:cover; display:block;"/>
        <% else %>
          <span id="vitrina-placeholder" style="color:#ccc; font-size:13px; font-family:Poppins,sans-serif;">Tocá para agregar una imagen</span>
        <% end %>
      </div>
    </div>

    <% c_num = Map.get(cfg2, "numerico", "#000") %>
    <div style={"background: #{c_sec}; border-radius:40px; width:100%; margin-top:16px; padding:10px; box-sizing:border-box; display:flex; gap:10px;"}>
      <div style="flex:1; background:#fff; border-radius:50px; padding:9px 0; text-align:center;">
        <p style={"margin:0; font-size:22px; font-weight:700; color: #{c_num}; font-family:Poppins,sans-serif;"}><%= length(@amigos) %></p>
        <p style="margin:2px 0 0; font-size:11px; color:#888; font-family:Poppins,sans-serif;">Seguidores</p>
      </div>
      <div style="flex:1; background:#fff; border-radius:50px; padding:9px 0; text-align:center;">
        <p style={"margin:0; font-size:22px; font-weight:700; color: #{c_num}; font-family:Poppins,sans-serif;"}><%= length(@amigos) %></p>
        <p style="margin:2px 0 0; font-size:11px; color:#888; font-family:Poppins,sans-serif;">Seguidos</p>
      </div>
      <div style="flex:1; background:#fff; border-radius:50px; padding:9px 0; text-align:center;">
        <p style={"margin:0; font-size:22px; font-weight:700; color: #{c_num}; font-family:Poppins,sans-serif;"}><%= length(@favoritos) %></p>
        <p style="margin:2px 0 0; font-size:11px; color:#888; font-family:Poppins,sans-serif;">Publicaciones</p>
      </div>
    </div>

    <div style={"height:5px; background: #{c_sec}; border-radius:10px; margin:20px 24px 0;"}></div>

    <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:3px; margin-top:16px;">
      <%= for pub <- (assigns[:publicaciones] || []) do %>
        <% primera = pub.imagen_url |> String.split(",") |> List.first() %>
        <div style="position:relative; width:100%; aspect-ratio:3/4; overflow:hidden; background:#f0f0f0; cursor:pointer;">
          <img src={primera} style="width:100%; height:100%; object-fit:cover; display:block;"/>
        </div>
      <% end %>
    </div>
    <%= if (assigns[:publicaciones] || []) == [] do %>
      <p style="text-align:center; color:#bbb; font-size:13px; font-family:Poppins,sans-serif; margin-top:24px;">Todavía no hay publicaciones</p>
    <% end %>
  </div>

  <div class="perfil-panel" id="perfil-panel-puntos" style="padding:16px;">
    <p style="font-size:30px; font-weight:800; color:#186904; font-family:Poppins,sans-serif; margin:0 0 2px;">DalePuntos</p>
    <p style="font-size:13px; color:#999; font-family:Poppins,sans-serif; margin:0 0 18px;">Canjeá cupones y subí de nivel</p>

    <div style="display:flex; gap:20px; align-items:flex-start;">
      <div style="position:relative; width:120px; flex-shrink:0;">
        <div id="dp-festejo">¡Nivel 2! 🎉</div>
        <svg id="dp-tritu" width="124" height="106" viewBox="0 0 140 120" style="display:block; margin:0 auto -10px; position:relative; z-index:3; overflow:visible;">
          <defs>
            <linearGradient id="dp-grad-cuerpo" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#34B24A"/>
              <stop offset="0.5" stop-color="#1E8A2E"/>
              <stop offset="1" stop-color="#125C1D"/>
            </linearGradient>
            <linearGradient id="dp-grad-tolva" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0" stop-color="#3DBF52"/>
              <stop offset="1" stop-color="#16701F"/>
            </linearGradient>
            <radialGradient id="dp-grad-rodillo" cx="0.35" cy="0.3" r="0.8">
              <stop offset="0" stop-color="#ffffff"/>
              <stop offset="1" stop-color="#C7E8CF"/>
            </radialGradient>
          </defs>
          <!-- tolva con gradiente y contorno negro parejo -->
          <path d="M16,10 Q14,6 20,6 L120,6 Q126,6 124,10 L96,46 Q94,50 88,50 L52,50 Q46,50 44,46 Z" fill="url(#dp-grad-tolva)" stroke="#0A0A0A" stroke-width="4" stroke-linejoin="round"/>
          <!-- brillo tolva -->
          <path d="M26,12 L52,12 L44,30 L34,30 Z" fill="#fff" opacity="0.18"/>
          <!-- cuerpo principal redondeado con gradiente -->
          <rect x="30" y="46" width="80" height="50" rx="16" fill="url(#dp-grad-cuerpo)" stroke="#0A0A0A" stroke-width="4"/>
          <!-- brillo superior del cuerpo -->
          <rect x="38" y="52" width="64" height="9" rx="4.5" fill="#fff" opacity="0.22"/>
          <!-- ventana con rodillos -->
          <rect x="42" y="60" width="56" height="30" rx="8" fill="#0E3914" stroke="#0A0A0A" stroke-width="3"/>
          <g class="dp-rodillo dp-rod-izq">
            <circle cx="58" cy="75" r="11" fill="url(#dp-grad-rodillo)" stroke="#0A0A0A" stroke-width="2.5"/>
            <g stroke="#0A0A0A" stroke-width="2.2"><line x1="58" y1="63" x2="58" y2="67"/><line x1="58" y1="83" x2="58" y2="87"/><line x1="46" y1="75" x2="50" y2="75"/><line x1="66" y1="75" x2="70" y2="75"/><line x1="49.5" y1="66.5" x2="52.5" y2="69.5"/><line x1="63.5" y1="80.5" x2="66.5" y2="83.5"/></g>
            <circle cx="58" cy="75" r="3" fill="#1E8A2E" stroke="#0A0A0A" stroke-width="1.5"/>
          </g>
          <g class="dp-rodillo dp-rod-der">
            <circle cx="82" cy="75" r="11" fill="url(#dp-grad-rodillo)" stroke="#0A0A0A" stroke-width="2.5"/>
            <g stroke="#0A0A0A" stroke-width="2.2"><line x1="82" y1="63" x2="82" y2="67"/><line x1="82" y1="83" x2="82" y2="87"/><line x1="70" y1="75" x2="74" y2="75"/><line x1="90" y1="75" x2="94" y2="75"/><line x1="73.5" y1="66.5" x2="76.5" y2="69.5"/><line x1="87.5" y1="80.5" x2="90.5" y2="83.5"/></g>
            <circle cx="82" cy="75" r="3" fill="#1E8A2E" stroke="#0A0A0A" stroke-width="1.5"/>
          </g>
          <!-- patas/base que apoya sobre el labio del tubo -->
          <rect x="38" y="94" width="64" height="9" rx="4" fill="#125C1D" stroke="#0A0A0A" stroke-width="3.5"/>
        </svg>

