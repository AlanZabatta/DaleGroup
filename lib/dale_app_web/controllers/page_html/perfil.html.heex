          <div id="dp-detalle-2" style="max-height:0; overflow:hidden; transition:max-height 0.3s ease;">
            <p style="font-size:12px; color:#555; font-family:Poppins,sans-serif; margin:8px 0 0; line-height:1.4;">&#127873; 1 mes gratis de <b style="color:#186904;">DalePlus</b>, sin tarjeta.</p>
          </div>
